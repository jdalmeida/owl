{
  "name": "@owl/server",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/next.js",
      "types": "./dist/next.d.ts"
    }
  },
  "files": ["dist", "admin-dist"],
  "scripts": {
    "build": "bun x tsup src/index.ts src/next.ts --format esm --dts --clean --external @owl/core && bun run build:admin",
    "build:admin": "cd admin && bun install && bun run build"
  },
  "dependencies": {
    "@owl/core": "workspace:*",
    "@owl/trama": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": { "optional": true }
  },
  "devDependencies": {
    "next": "^15.1.0",
    "tsup": "^8.3.5",
    "typescript": "^5"
  }
}
